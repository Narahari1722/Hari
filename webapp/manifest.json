{
  "_version": "1.49.0",
  "sap.app": {
    "id": "com.aifalabs.materiallist",
    "type": "application",
    "title": "Material List",
    "description": "Material List Application",
    "applicationVersion": { "version": "0.0.1" },
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata/sap/ZDDLS_SAMPLE_VINAY_CDS/",
        "type": "OData",
        "settings": {
          "odataVersion": "2.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": true }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "com.aifalabs.materiallist.view.MainView",
      "type": "XML",
      "async": true,
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {}
      }
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "defaultBindingMode": "TwoWay",
          "defaultCountMode": "Request"
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.aifalabs.materiallist.i18n.i18n"
        }
      }
    }
  }
}